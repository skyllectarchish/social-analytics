# ClickHouse Cloud
CLICKHOUSE_HOST=your-host.clickhouse.cloud
CLICKHOUSE_PORT=8443          # HTTPS port — used by the FastAPI app (clickhouse-connect)
CLICKHOUSE_NATIVE_PORT=9440   # Secure native TCP port — used by run_migrations.py (clickhouse-migrations)
CLICKHOUSE_USER=your-clickhouse-user
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=social_analytics

# JWT — GENERATE a random 64-char key: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE-ME-generate-with-secrets-token-urlsafe
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Meta / Instagram
# Uses the Instagram Login API (direct Instagram OAuth — no Facebook Page required).
# In the Meta dev console (https://developers.facebook.com/apps/<your-app>/) add the
# "Instagram" product and configure "Instagram → API setup with Instagram Business Login".
# Copy the Instagram App ID / Secret shown there into the values below.
# META_REDIRECT_URI must also be registered there under "Business Login Settings →
# Embedded OAuth redirect URI".
META_APP_ID=your-instagram-app-id
META_APP_SECRET=your-instagram-app-secret
META_REDIRECT_URI=http://localhost:5173/callback

# OAuth state CSRF token expiry (seconds). The /connect endpoint signs a JWT
# state bound to the current user; /callback rejects it after this many seconds.
OAUTH_STATE_TTL_SECONDS=600

# Frontend
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Tier 2 / F4 — Claude Haiku for comment sentiment + topic labelling.
# Optional: leave blank if you're not running the sentiment_batch /
# topic_clustering jobs. The API itself starts without it.
ANTHROPIC_API_KEY=

# Tier 2 — in-process APScheduler for batch jobs (competitor_sync daily,
# sentiment_batch hourly, topic_clustering weekly). Set to "false" when
# running cron externally or in a multi-worker deploy where only one
# worker should schedule jobs. Default: true.
ENABLE_SCHEDULER=true
SCHEDULER_COMPETITOR_SYNC_HOUR=3
SCHEDULER_SENTIMENT_BATCH_MINUTES=60
SCHEDULER_TOPIC_CLUSTERING_DAY=0
SCHEDULER_TOPIC_CLUSTERING_HOUR=4
