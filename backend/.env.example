# ClickHouse Cloud
CLICKHOUSE_HOST=your-host.clickhouse.cloud
CLICKHOUSE_PORT=8443          # HTTPS port — used by the FastAPI app (clickhouse-connect)
CLICKHOUSE_NATIVE_PORT=9440   # Secure native TCP port — used by run_migrations.py (clickhouse-migrations)
CLICKHOUSE_USER=your-clickhouse-user
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=social_analytics

# JWT — GENERATE a random 64-char key: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE-ME-generate-with-secrets-token-urlsafe
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Meta / Instagram
# Uses the Instagram Login API (direct Instagram OAuth — no Facebook Page required).
# In the Meta dev console (https://developers.facebook.com/apps/<your-app>/) add the
# "Instagram" product and configure "Instagram → API setup with Instagram Business Login".
# Copy the Instagram App ID / Secret shown there into the values below.
# META_REDIRECT_URI must also be registered there under "Business Login Settings →
# Embedded OAuth redirect URI".
META_APP_ID=your-instagram-app-id
META_APP_SECRET=your-instagram-app-secret
META_REDIRECT_URI=http://localhost:5173/auth/instagram/callback

# (Optional) System-wide Facebook token and Instagram Business User ID.
# Since the direct Instagram Login API does not support Business Discovery (competitor lookup),
# you can generate a system-wide long-lived token via Facebook Login/Developer portal
# for an eligible Business/Creator account and store it here. The backend will automatically
# route competitor benchmarking requests through graph.facebook.com using this token.
META_SYSTEM_TOKEN=
META_SYSTEM_IG_USER_ID=

# Google / YouTube
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3, YouTube Analytics API v2
# IMPORTANT: Google redirects to the FRONTEND callback page (not the backend).
# The frontend page then calls the backend with the user's JWT.
# Register this URI in Google Cloud Console → Credentials → Authorized redirect URIs.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/youtube/callback

# OAuth state CSRF token expiry (seconds). The /connect endpoint signs a JWT
# state bound to the current user; /callback rejects it after this many seconds.
OAUTH_STATE_TTL_SECONDS=600

# Frontend
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Tier 2 / F4 — Claude API key. Used by the Tier 2 comment-sentiment +
# topic-clustering batch jobs only. Leave blank if you're not running
# those jobs. The Tier 4 AI Copilot features use Ollama Cloud (below).
ANTHROPIC_API_KEY=

# Tier 2 — in-process APScheduler for batch jobs (competitor_sync daily,
# sentiment_batch hourly, topic_clustering weekly). Set to "false" when
# running cron externally or in a multi-worker deploy where only one
# worker should schedule jobs. Default: true.
ENABLE_SCHEDULER=true
# Daily own-account sync: refreshes each user's profile/media/insights and
# renews long-lived tokens expiring within TOKEN_REFRESH_THRESHOLD_DAYS.
# Runs an hour before competitor_sync so its self-snapshot sees fresh data.
SCHEDULER_ACCOUNT_SYNC_HOUR=2
ACCOUNT_SYNC_LOOKBACK_DAYS=7
TOKEN_REFRESH_THRESHOLD_DAYS=10
SCHEDULER_COMPETITOR_SYNC_HOUR=3
SCHEDULER_SENTIMENT_BATCH_MINUTES=60
SCHEDULER_TOPIC_CLUSTERING_DAY=0
SCHEDULER_TOPIC_CLUSTERING_HOUR=4

# Story analytics retention — snapshot live stories + their insights every
# N hours so they survive Meta's 24h expiry (6h ≈ 4 captures per story).
SCHEDULER_STORY_SNAPSHOT_HOURS=6

# Comment-to-DM keyword funnels — how often the runner scans recent posts
# for trigger comments, how far back it looks for posts, and the per-user
# DM cap per run (messaging rate-limit safety).
SCHEDULER_DM_FUNNEL_MINUTES=15
DM_FUNNEL_MEDIA_LOOKBACK_DAYS=7
DM_FUNNEL_MAX_SENDS_PER_RUN=25

# Tier 4 — Weekly digest scheduled job (Phase F)
SCHEDULER_WEEKLY_DIGEST_DAY=0
SCHEDULER_WEEKLY_DIGEST_HOUR=8

# Tier 4 — Admin endpoint auth (Phase F). Leave blank to disable
# /api/admin/* routes. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Tier 4 — Ollama Cloud (https://ollama.com). Powers the AI Copilot
# features (weekly digest, content ideas, post diagnostic, caption
# studio). The API starts without OLLAMA_API_KEY, but every /api/ai/*
# route that needs to call the LLM returns 503 until it is set.
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# Tier 4 — AI Copilot quota and behavior knobs.
AI_MONTHLY_CALL_LIMIT=100
AI_DIGEST_STREAMING_ENABLED=true
AI_REQUEST_TIMEOUT_S=120
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_WINDOW_S=60
AI_CIRCUIT_BREAKER_COOLDOWN_S=300
AI_TELEMETRY_MAX_EVENTS_PER_REQUEST=200

# YouTube Phase 2 — Webhook Intelligence
# Set to ngrok public URL (e.g. https://abc123.ngrok.io) to enable PubSubHubbub.
# Leave blank to use daily polling fallback.
WEBHOOK_BASE_URL=

ARCHIVE_MINER_MAX_VIDEOS_PER_RUN=20
SCHEDULER_ARCHIVE_MINER_DAY=6
SCHEDULER_ARCHIVE_MINER_HOUR=3
DEFAULT_RPM_USD=3.0
COMPETITOR_LIMIT_STANDARD=5
COMPETITOR_LIMIT_PREMIUM=25