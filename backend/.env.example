# ClickHouse Cloud
CLICKHOUSE_HOST=your-host.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=your-key-id
CLICKHOUSE_PASSWORD=your-key-secret
CLICKHOUSE_DATABASE=social_analytics

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this-to-random-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Meta / Instagram
META_APP_ID=your-facebook-app-id
META_APP_SECRET=your-facebook-app-secret
META_REDIRECT_URI=http://localhost:5173/callback

# Frontend
FRONTEND_URL=http://localhost:5173
